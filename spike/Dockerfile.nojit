FROM php:8.1-cli-alpine

# Worst-case shared-host realism: no opcache, no JIT.
# Some budget hosts disable opcache for CLI; this measures that floor.
RUN { \
        echo "memory_limit=256M"; \
        echo "opcache.enable_cli=0"; \
    } > /usr/local/etc/php/conf.d/spike.ini

WORKDIR /spike
COPY spike.php .

CMD ["php", "spike.php", "5000"]
